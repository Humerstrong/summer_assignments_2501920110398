//to convert decimal to binary
#include <stdio.h>

int main() {
    int n, binary[32], i = 0;

    printf("Enter a decimal number: ");
    scanf("%d", &n);

    if (n == 0) {
        printf("Binary = 0");
        return 0;
    }

    while (n > 0) {
        binary[i] = n % 2;
        n = n / 2;
        i++;
    }

    printf("Binary = ");
    for (int j = i - 1; j >= 0; j--)
        printf("%d", binary[j]);

    return 0;
}




//to convert binary to decimal
#include <stdio.h>

int main() {
    int binary, digit, decimal = 0, base = 1;

    printf("Enter a binary number: ");
    scanf("%d", &binary);

    while (binary > 0) {
        digit = binary % 10;
        decimal += digit * base;
        base *= 2;
        binary /= 10;
    }

    printf("Decimal = %d\n", decimal);

    return 0;
}



//to count set bits of a number
#include <stdio.h>

int main() {
    int n, count = 0;

    printf("Enter a number: ");
    scanf("%d", &n);

    while (n > 0) {
        if (n % 2 == 1)
            count++;

        n /= 2;
    }

    printf("Number of set bits = %d\n", count);

    return 0;
}


//to find x^n without using pow
#include <stdio.h>

int main() {
    int base, exponent, result = 1;

    printf("Enter base and exponent: ");
    scanf("%d %d", &base, &exponent);

    for (int i = 1; i <= exponent; i++) {
        result *= base;
    }

    printf("%d^%d = %d\n", base, exponent, result);

    return 0;
}
