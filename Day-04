//to print fibonacci series
#include <stdio.h>

int main() {
    int n, a = 0, b = 1, c;

    printf("Enter the number of terms: ");
    scanf("%d", &n);

    printf("Fibonacci Series:\n");

    for (int i = 1; i <= n; i++) {
        printf("%d ", a);
        c = a + b;
        a = b;
        b = c;
    }

    return 0;
}


//find nth term of fibonacci series
#include <stdio.h>

int main() {
    int n, a = 0, b = 1, c;

    printf("Enter n: ");
    scanf("%d", &n);

    if (n == 1)
        printf("Nth term = %d\n", a);
    else if (n == 2)
        printf("Nth term = %d\n", b);
    else {
        for (int i = 3; i <= n; i++) {
            c = a + b;
            a = b;
            b = c;
        }
        printf("Nth term = %d\n", b);
    }

    return 0;
}



//check if the number is armstrong or not
#include <stdio.h>

int main() {
    int n, original, digit, sum = 0;

    printf("Enter a number: ");
    scanf("%d", &n);

    original = n;

    while (n != 0) {
        digit = n % 10;
        sum += digit * digit * digit;
        n = n / 10;
    }

    if (sum == original)
        printf("%d is an Armstrong Number.\n", original);
    else
        printf("%d is not an Armstrong Number.\n", original);

    return 0;
}

//to get amrstrong numbers in rnage
#include <stdio.h>

int main() {
    int start, end, i, temp, digit, sum;

    printf("Enter starting and ending numbers: ");
    scanf("%d %d", &start, &end);

    printf("Armstrong Numbers are:\n");

    for (i = start; i <= end; i++) {
        temp = i;
        sum = 0;

        while (temp != 0) {
            digit = temp % 10;
            sum += digit * digit * digit;
            temp = temp / 10;
        }

        if (sum == i)
            printf("%d ", i);
    }

    return 0;
}
